# انسخ هذا الملف باسم  .env  ثم ضع المفتاح بعد علامة =
# المفتاح هو نفسه الموجود في Render ← dsd-backend ← Environment ← WA_BRIDGE_KEY
# بلا علامات تنصيص، وبلا مسافات حول علامة =

WA_BRIDGE_KEY=

# اختياري — لا تلمسه إلا عند الحاجة:
# WA_BRIDGE_CHROME=C:\Program Files\Google\Chrome\Application\chrome.exe
