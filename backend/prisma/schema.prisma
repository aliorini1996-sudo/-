generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// القيم المسموحة موثّقة بجانب كل حقل

// مالك المنصّة (بائع النظام) — يدير كل الشركات والاشتراكات
model SuperAdmin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

// الشركة المشتركة في النظام — الكيان الأعلى لعزل البيانات
model Tenant {
  id            String    @id @default(uuid())
  name          String    // اسم الشركة المشتركة
  isActive      Boolean   @default(true)  // تعطيل الاشتراك يمنع كل مستخدميها من الدخول
  plan          String    @default("basic") // basic | pro | enterprise (لم يعد يُعرض في الواجهة)
  // محور عزل العموديّات: distribution (التوزيع/المناديب) | restaurant (المطاعم/الكاشير).
  // القيمة الافتراضية distribution ⇒ كل الشركات القائمة تُصنَّف توزيعاً عند db push دون لمس القاعدة.
  vertical      String    @default("distribution") // distribution | restaurant
  maxSalesReps  Int?                          // الحد الأقصى لعدد المناديب (null = غير محدود)
  maxAdminUsers Int?                          // الحد الأقصى لمستخدمي لوحة الشركة (null = غير محدود)
  maxPosStations Int?                         // مطاعم: الحد الأقصى لنقاط البيع/الكاشير (null = غير محدود/لا ينطبق)
  maxBranches    Int?                         // مطاعم: الحد الأقصى للفروع (null = غير محدود/لا ينطبق)
  erpEnabled    Boolean   @default(false)     // صلاحية ربط ERP — يتحكّم بها المالك حسب الاشتراك
  subscriptionEndsAt DateTime?            // تاريخ انتهاء الاشتراك (null = غير محدود)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  admins          Admin[]
  salesReps       SalesRep[]
  categories      ProductCategory[]
  products        Product[]
  customers       Customer[]
  invoices        Invoice[]
  receipts        Receipt[]
  accountEntries  AccountEntry[]
  notifications   Notification[]
  settings        CompanySettings?
  erpIntegration  ErpIntegration?
  erpSyncLogs     ErpSyncLog[]
  vanLoads        VanLoad[]
  repLocations    RepLocation[]
  repSettlements  RepSettlement[]
  importBatches   ImportBatch[]

  // عمودية المطاعم (M2+) — علاقات ظهر إضافية اختيارية
  restaurantAreas   RestaurantArea[]
  restaurantTables  RestaurantTable[]
  menuCategories    MenuCategory[]
  menuItems         MenuItem[]
  modifierGroups    ModifierGroup[]
  modifiers         Modifier[]
  orders            Order[]

  @@index([vertical])
  @@map("tenants")
}

// دفعة استيراد — تسجّل ما أُنشئ في كل رفعة لإتاحة التراجع/الإزالة الآمنة
model ImportBatch {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind      String   // customers | products | balances | ledger | prices
  count     Int      @default(0)
  recordIds String   // JSON: مصفوفة معرّفات السجلات المُنشأة (للتراجع)
  createdBy String?
  reverted  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("import_batches")
}

model Admin {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN | MANAGER | ACCOUNTANT
  isActive     Boolean  @default(true)
  emailVerified Boolean @default(false) // تأكيد ملكية البريد (تحقّق التسجيل الذاتي)

  // Company admin permissions
  canAccessDashboard       Boolean @default(true)
  canManageCustomers       Boolean @default(true)
  canManageProducts        Boolean @default(true)
  canManageSalesReps       Boolean @default(true)
  canManageInvoices        Boolean @default(true)
  canManageReceipts        Boolean @default(true)
  canViewReports           Boolean @default(true)
  canManageVanStock        Boolean @default(true)
  canManageTracking        Boolean @default(true)
  canManageCompanySettings Boolean @default(true)
  canManageCompanyUsers    Boolean @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@map("admins")
}

model SalesRep {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String?
  username     String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  fcmToken     String?

  // Sales permissions
  canCreateInvoice  Boolean @default(true)
  canSellOnCredit   Boolean @default(true)
  canSellInCash     Boolean @default(true)
  canEditInvoice    Boolean @default(false)
  canDeleteInvoice  Boolean @default(false)
  canCancelInvoice  Boolean @default(false)

  // Pricing permissions
  canChangePrice    Boolean @default(false)
  maxDiscountPct    Float   @default(0)
  canSellBelowPrice Boolean @default(false)

  // Collection permissions
  canCreateReceipt  Boolean @default(true)
  canEditReceipt    Boolean @default(false)
  canCancelReceipt  Boolean @default(false)

  // Customer permissions
  canAddCustomer    Boolean @default(false)
  canEditCustomer   Boolean @default(false)
  canViewStatement  Boolean @default(true)

  // إظهار رصيد التحصيل المتراكم للمندوب على شاشته الرئيسية (يحدّده الأدمن لكل مندوب)
  showCollectionBalance Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Van stock permission — هل يستطيع المندوب إدارة مخزون سيارته
  canManageVanStock Boolean @default(true)

  // GPS tracking — آخر موقع معروف + إتاحة التتبّع لهذا المندوب
  canBeTracked Boolean   @default(true)
  lastLat      Float?
  lastLng      Float?
  lastSeenAt   DateTime?

  invoices      Invoice[]
  receipts      Receipt[]
  notifications Notification[]
  vanLoads      VanLoad[]
  locations     RepLocation[]
  settlements   RepSettlement[]

  @@index([tenantId])
  @@map("sales_reps")
}

model ProductCategory {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())
  products  Product[]

  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id           String         @id @default(uuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code         String
  name         String
  barcode      String?
  unit         String
  basePrice    Float
  taxPct       Float          @default(15)
  image        String?        // صورة الصنف (base64 data URL)
  itemCode     String?        // كود الصنف للفوترة الإلكترونية (EGS/GS1)
  itemCodeType String?        @default("EGS") // EGS | GS1
  unitCode     String?        // كود الوحدة حسب جدول المزوّد (ETA)
  status       String         @default("ACTIVE") // ACTIVE | INACTIVE
  damagedReturnToStock Boolean @default(false) // سياسة الصنف: هل يعود مرتجعه التالف لمخزون السيارة؟ (يضبط افتراض المرتجع)
  categoryId   String?
  category     ProductCategory? @relation(fields: [categoryId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  priceTiers     PriceTier[]
  customerPrices CustomerPrice[]
  invoiceItems   InvoiceItem[]
  vanLoadItems   VanLoadItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("products")
}

model PriceTier {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  minQty    Float
  maxQty    Float?
  price     Float
  createdAt DateTime @default(now())

  @@map("price_tiers")
}

model Customer {
  id             String         @id @default(uuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String         @default(cuid())
  name           String
  businessName   String?
  commercialReg  String?
  taxNumber      String?
  phone          String
  altPhone       String?
  email          String?
  city           String?
  district       String?
  address        String?
  channel        String?        // قناة البيع: MT | WHOLESALE | TT | DISCOUNTER | CASH_VAN | ECOMMERCE
  status         String         @default("ACTIVE") // ACTIVE | INACTIVE | BLOCKED

  creditLimit    Float @default(0)
  paymentDays    Int   @default(30)
  balance        Float @default(0)
  totalSales     Float @default(0)
  totalCollected Float @default(0)

  // idempotency + تبعية العمل دون اتصال: عميل يُنشأ أوف‑لاين يحمل clientRef، والفاتورة/السند
  // له تشير إليه بـ customerClientRef فيحلّه الخادم إلى id الحقيقي عند الرفع (انظر M5).
  //
  // ⚠️ لا قيد @@unique على clientRef هنا (بخلاف Invoice/Receipt): إضافته على جدول customers
  // الحامل لبيانات فعلية يُفشل `prisma db push` (يطلب --accept-data-loss). فالidempotency
  // للعميل على مستوى التطبيق (findFirst-then-create) — كافٍ لأن المزامنة متسلسلة على جهاز
  // واحد فلا تكرار متزامن. أضِف فهرساً عادياً لتسريع البحث بلا القيد الفريد.
  clientRef       String?
  clientCreatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerPrices CustomerPrice[]
  invoices       Invoice[]
  receipts       Receipt[]
  accountEntries AccountEntry[]
  notifications  Notification[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, clientRef]) // فهرس عادي (لا قيد فريد) — يسرّع حلّ customerClientRef
  @@map("customers")
}

model CustomerPrice {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, productId])
  @@map("customer_prices")
}

// محتوى الصفحة التعريفية التسويقية والصفحات التابعة (CMS) — صف واحد بمعرّف ثابت "main"
model SiteContent {
  id        String   @id @default("main")
  data      String   // JSON كامل لكل محتوى الصفحة التعريفية والصفحات الفرعية
  updatedAt DateTime @updatedAt @default(now())

  @@map("site_content")
}

model Invoice {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number      String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  salesRepId  String
  salesRep    SalesRep @relation(fields: [salesRepId], references: [id])
  type        String   @default("CREDIT") // CASH | CREDIT | RETURN
  status      String   @default("CONFIRMED") // DRAFT | CONFIRMED | CANCELLED
  returnReason String? // سبب الإرجاع (للمرتجعات): NORMAL | DAMAGED | EXCHANGE
  returnToStock Boolean @default(true) // هل يعود المرتجع لمخزون السيارة؟ (الأدمن يتحكّم؛ التالف=لا افتراضياً)
  invoiceDate DateTime @default(now())
  dueDate     DateTime?
  notes       String?

  subtotal     Float
  discountPct  Float @default(0)
  discountAmt  Float @default(0)
  taxAmt       Float @default(0)
  total        Float
  paidAmt      Float @default(0)
  remainingAmt Float

  // الفوترة الإلكترونية (اعتماد حكومي) — تُملأ عند الإرسال للمزوّد
  einvoiceProvider    String?   // zatca | eta | peppol | ttn | none
  einvoiceStatus      String?   // generated | submitted | cleared | pending | not_implemented | error
  einvoiceUuid        String?   // معرّف الاعتماد (UUID من ETA/Peppol)
  einvoiceQr          String?   // حمولة/رابط QR إن وُجد
  einvoiceSubmittedAt DateTime?

  // مفتاح idempotency: UUID يولّده العميل مرّة لكل مستند. عند تكرار الرفع (إعادة محاولة/شبكة
  // متقطّعة) يعيد الخادم الفاتورة القائمة بدل إنشاء مكرّرة. أساس العمل دون اتصال (Outbox).
  clientRef       String?
  clientCreatedAt DateTime? // لحظة الإنشاء على جهاز المندوب (قد تسبق الرفع بساعات)

  // إضافات عمودية المطاعم (M3) — كلها بقيم افتراضية/nullable (لا تمسّ فواتير التوزيع)
  orderType        String? @default("DINE_IN") // DINE_IN | TAKEAWAY | DELIVERY (للمطاعم فقط)
  serviceChargeAmt Float   @default(0)          // رسوم الخدمة (للمطاعم)
  tipAmt           Float   @default(0)          // إكرامية (ليست إيراداً ولا ضريبة)
  shiftId          String?                       // ربط بوردية الكاشير (M4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          InvoiceItem[]
  receiptItems   ReceiptInvoice[]
  accountEntries AccountEntry[]
  order          Order?          // الطلب الذي وُلِّدت منه فاتورة المطعم (علاقة ظهر، بلا عمود)

  @@unique([tenantId, number])
  @@unique([tenantId, clientRef])
  @@index([tenantId])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  // تخفيف إضافي غير مُدمِّر (DROP NOT NULL): بند التوزيع يظلّ يملأ productId كما اليوم،
  // أما بنود فاتورة المطعم (عمودية restaurant) فتشير إلى MenuItem وتترك productId فارغاً.
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  // بنود فاتورة المطعم (M3) — تشير إلى MenuItem بدل Product، مع أثر رجعي للطلب وتكلفة مجمّدة
  menuItemId  String?
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id])
  orderItemId String?
  unitCost    Float    @default(0) // تكلفة الصنف لحظة البيع (لحساب COGS في M6)
  qty         Float
  unitPrice   Float
  discountPct Float   @default(0)
  discountAmt Float   @default(0)
  taxPct      Float
  taxAmt      Float
  lineTotal   Float

  @@index([menuItemId])
  @@map("invoice_items")
}

model Receipt {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number        String
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  salesRepId    String
  salesRep      SalesRep @relation(fields: [salesRepId], references: [id])
  receiptDate   DateTime @default(now())
  amount        Float
  paymentMethod String   @default("CASH") // CASH | BANK_TRANSFER | POS | CHEQUE
  chequeNumber  String?
  bankName      String?
  notes         String?
  status        String   @default("ACTIVE") // ACTIVE | CANCELLED

  // idempotency للعمل دون اتصال (انظر Invoice.clientRef)
  clientRef       String?
  clientCreatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoiceItems   ReceiptInvoice[]
  accountEntries AccountEntry[]

  @@unique([tenantId, number])
  @@unique([tenantId, clientRef])
  @@index([tenantId])
  @@map("receipts")
}

model ReceiptInvoice {
  id        String  @id @default(uuid())
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  amount    Float

  @@unique([receiptId, invoiceId])
  @@map("receipt_invoices")
}

model AccountEntry {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  receiptId   String?
  receipt     Receipt? @relation(fields: [receiptId], references: [id])
  type        String   // INVOICE_DEBIT | INVOICE_CREDIT | RECEIPT_CREDIT | RECEIPT_DEBIT | ADJUSTMENT_DEBIT | ADJUSTMENT_CREDIT
  debit       Float    @default(0)
  credit      Float    @default(0)
  balance     Float
  description String
  entryDate   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@map("account_entries")
}

model CompanySettings {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  address       String?
  taxNumber     String?
  commercialReg String?
  phone         String?
  email         String?
  logo          String?  // شعار الشركة (base64 data URL)
  primaryColor  String?  // لون الترويسة الأساسي (hex)
  headerStyle   String?  @default("classic") // classic | banner | minimal
  trackingEnabled Boolean @default(false) // تفعيل تتبّع مواقع المناديب GPS على مستوى الشركة

  // --- التدويل (المرحلة 0): أعمدة إضافية بقيم افتراضية — لا فقد بيانات ---
  countryCode      String  @default("SA")    // ISO alpha-2: دولة الشركة
  currency         String  @default("SAR")   // عملة الفوترة (مشتقّة من الدولة)
  defaultVatPct    Float   @default(15)       // نسبة الضريبة الافتراضية للدولة
  einvoiceProvider String  @default("zatca") // zatca | eta | peppol | ttn | none

  // --- بيانات ربط الفوترة الإلكترونية (تُدخلها كل شركة) — للمزوّدات الحكومية ETA/Peppol/TTN ---
  einvoiceEnabled         Boolean @default(false)     // تفعيل الإرسال الحكومي لهذه الشركة
  einvoiceEnv             String  @default("preprod") // preprod | production
  einvoiceClientId        String?                     // معرّف العميل (من بوابة المزوّد/الوسيط)
  einvoiceClientSecret    String?                     // السرّ (يُدخله العميل — لا يُعرض بعدها)
  einvoiceActivityCode    String?                     // كود النشاط (ETA)
  einvoiceBranchCode      String?                     // كود الفرع/الموقع
  einvoiceIntermediaryUrl String?                     // رابط الوسيط/المُجمِّع المعتمد (اختياري)

  updatedAt     DateTime @updatedAt

  @@map("company_settings")
}

model ErpIntegration {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enabled           Boolean  @default(false)
  provider          String   @default("CUSTOM") // CUSTOM | ODOO | SAP | ZOHO | OTHER
  baseUrl           String?
  authType          String   @default("NONE") // NONE | API_KEY | BEARER | BASIC
  apiKey            String?
  bearerToken       String?
  basicUsername     String?
  basicPassword     String?
  customersEndpoint String?
  productsEndpoint  String?
  invoicesEndpoint  String?
  receiptsEndpoint  String?
  syncCustomers     Boolean  @default(true)
  syncProducts      Boolean  @default(true)
  syncInvoices      Boolean  @default(true)
  syncReceipts      Boolean  @default(true)
  lastSyncAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@map("erp_integrations")
}

model ErpSyncLog {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resource   String    // customers | products | invoices | receipts | connection
  direction  String    @default("OUTBOUND")
  status     String    // SUCCESS | FAILED
  count      Int       @default(0)
  message    String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([tenantId])
  @@index([resource])
  @@map("erp_sync_logs")
}

model Notification {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type       String    // CREDIT_LIMIT_EXCEEDED | DISCOUNT_LIMIT_EXCEEDED | OVERDUE_PAYMENT | INVOICE_CANCELLED | PRICE_MODIFIED | RECEIPT_CANCELLED
  title      String
  body       String
  salesRepId String?
  salesRep   SalesRep? @relation(fields: [salesRepId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  isRead     Boolean   @default(false)
  data       String?   // JSON كنص
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@map("notifications")
}

// تحميل بضاعة لسيارة المندوب — حركة مخزون (LOAD=تحميل، UNLOAD=تنزيل للمستودع، ADJUST=تسوية)
model VanLoad {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesRepId  String
  salesRep    SalesRep @relation(fields: [salesRepId], references: [id])
  type        String   @default("LOAD") // LOAD | UNLOAD | ADJUST
  note        String?
  createdBy   String?  // "REP" | "ADMIN" — من سجّل الحركة
  createdAt   DateTime @default(now())

  items VanLoadItem[]

  @@index([tenantId])
  @@index([salesRepId])
  @@map("van_loads")
}

model VanLoadItem {
  id        String  @id @default(uuid())
  vanLoadId String
  vanLoad   VanLoad @relation(fields: [vanLoadId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Float   // موجب للتحميل/التسوية الزائدة، يُفسَّر حسب نوع VanLoad

  @@index([vanLoadId])
  @@map("van_load_items")
}

// نقطة موقع GPS للمندوب — سجلّ زمني لرسم خطّ السير ومعرفة الموقع الحالي
model RepLocation {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesRepId String
  salesRep   SalesRep @relation(fields: [salesRepId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  accuracy   Float?   // دقة الموقع بالأمتار
  speed      Float?   // السرعة م/ث إن توفّرت
  capturedAt DateTime // وقت التقاط الموقع على جهاز المندوب
  createdAt  DateTime @default(now())

  @@index([tenantId, salesRepId, capturedAt])
  @@map("rep_locations")
}

// استلام تحصيل من المندوب — كل مرّة يسلّم فيها المندوب نقدًا للإدارة يُسجَّل هنا.
// رصيد التحصيل لدى المندوب = مجموع سنداته النشطة − مجموع ما سُجّل هنا من استلامات.
model RepSettlement {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesRepId String
  salesRep   SalesRep @relation(fields: [salesRepId], references: [id], onDelete: Cascade)
  amount     Float
  note       String?
  createdBy  String?  // اسم/معرّف الأدمن الذي استلم
  settledAt  DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([tenantId, salesRepId])
  @@map("rep_settlements")
}

// ============================================================================
// العملاء المحتملون (Leads) — على مستوى المنصّة (مالك المنصّة / السوبر أدمن)
// شركات توزيع/جملة حول العالم قد تشترك في Field Sales. مستقلة عن أي Tenant.
// ============================================================================

// عميل محتمل واحد (شركة) — تُجمع من الخرائط/المصادر العامة أو يدوياً
model Lead {
  id          String  @id @default(uuid())
  name        String  // اسم النشاط/الشركة
  phone       String?
  email       String?
  website     String?
  address     String?
  city        String?
  country     String? // اسم الدولة (للعرض)
  countryCode String? // ISO-3166 alpha-2 (للتجميع والفلترة)
  category    String? // نوع النشاط (تجارة جملة، موزّع...)
  lat         Float?
  lng         Float?
  mapsUrl     String? // رابط الموقع على الخريطة

  source   String  @default("manual") // manual | csv | osm | google | social | api
  sourceId String? @unique            // مفتاح إزالة التكرار لكل مصدر (مثل "osm:node/123")

  // خط أنابيب المبيعات
  stage   String  @default("NEW") // NEW | CONTACTED | QUALIFIED | PROPOSAL | WON | LOST
  score   Int?    // ملاءمة 1-10 (تأهيل آلي/يدوي)
  scoreNote String?
  assignedTo String? // معرّف/اسم مسؤول المتابعة (سوبر أدمن)
  convertedTenantId String? // عند التحويل لمشترك فعلي
  notes   String?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?

  // انسحاب من مراسلة واتساب — يُضبط تلقائياً عند ردّ العميل بكلمة إلغاء/stop.
  // مُستثنى من كل استهداف لاحق (سياسة واتساب + حماية تقييم جودة الرقم).
  waOptOut Boolean @default(false)

  // نوع الهاتف: true جوّال · false أرضي مؤكَّد · null غير معروف (لا يُقصى).
  // أرقام الليدز المصيدة أغلبها أرضي (145 من 183 محاولة إرسال قياساً) — والأرضي
  // يُهدر الحصّة ويُضعف سمعة الرقم. لا يُحذف العميل: يُستبعد من استهداف واتساب فقط.
  phoneIsMobile Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities LeadActivity[]
  waMessages WaMessage[]

  @@index([stage])
  @@index([countryCode])
  @@index([source])
  @@index([nextFollowUpAt])
  @@map("leads")
}

// سجلّ رسائل واتساب (صادر/وارد) — يغذّي الحدّ اليومي وتتبّع التسليم/القراءة ومطابقة الردود.
// حالات التسليم تصل عبر webhook من Meta وتُحدَّث على waId.
model WaMessage {
  id        String  @id @default(uuid())
  waId      String? @unique // معرّف رسالة واتساب (wamid) — مفتاح تحديث الحالة من الـwebhook
  leadId    String?
  lead      Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  phone     String  // الرقم مطبَّعاً (أرقام فقط) — مفتاح مطابقة الردود الواردة
  direction String  @default("OUT") // OUT | IN
  body      String? // نصّ الرسالة (أو نصّ الردّ الوارد)
  template  String? // اسم القالب المعتمد (للصادر بوضع القالب)
  status    String  @default("SENT") // SENT | DELIVERED | READ | FAILED | RECEIVED
  error     String?
  // هل أكّد واتساب التسليم فعلاً (ACK≥1)؟ الكود القديم كان يُعلّم SENT بمجرّد أن يعود
  // sendMessage — وهو يعود قبل التسليم — فوُجدت رسائل «ناجحة» لم تخرج قطّ.
  // false على رسالة SENT قديمة = تحتاج مصالحة مع واتساب.
  ackVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([phone])
  @@index([createdAt])
  @@map("wa_messages")
}

// سجلّ نشاط/متابعة على عميل محتمل (مكالمة، ملاحظة، تغيير مرحلة...)
model LeadActivity {
  id      String @id @default(uuid())
  leadId  String
  lead    Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type    String // NOTE | CALL | EMAIL | MEETING | STAGE_CHANGE | SCORE | IMPORT
  content String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("lead_activities")
}

// سجلّ عملية بحث آلي (لتتبّع مصادر الجمع وتجنّب التكرار وعرض التاريخ)
model LeadSearch {
  id       String @id @default(uuid())
  provider String // osm | google
  query    String // نوع النشاط المبحوث عنه
  country  String?
  city     String?
  status   String @default("done") // running | done | failed
  found    Int    @default(0) // إجمالي النتائج من المصدر
  imported Int    @default(0) // الجدد المُضافون بعد إزالة التكرار
  error    String?
  createdBy String?
  createdAt DateTime @default(now())

  @@map("lead_searches")
}

// ============================================================================
// تحليلات زيارات الموقع التعريفي — على مستوى المنصّة (مالك المنصّة / السوبر أدمن)
// تُسجَّل زيارة لكل تحميل صفحة عامّة، مع تحديد الدولة/المدينة من IP (بدون تخزين IP خام).
// ============================================================================
model Visit {
  id           String   @id @default(uuid())
  path         String   // مسار الصفحة (/ , /blog , /en ...)
  lang         String?  // ar | en
  referrer     String?  // الرابط المُحيل الكامل
  referrerHost String?  // نطاق المُحيل (google.com ...) أو null للزيارة المباشرة
  country      String?
  countryCode  String?  // ISO alpha-2
  region       String?
  city         String?
  ipHash       String?  // بصمة IP مجزّأة (لعدّ الزوّار الفريدين دون تخزين IP الخام)
  userAgent    String?
  isBot        Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([countryCode])
  @@index([referrerHost])
  @@map("visits")
}

// ============================================================================
// عمودية المطاعم (Field Restaurant) — القوائم والصالات والطاولات (M2)
// كلها جداول جديدة (إضافية بحتة)، معزولة بـtenantId، والوصول محكوم بـrequireVertical('restaurant').
// ============================================================================

// صالة/منطقة داخل المطعم (تُجمَّع تحتها الطاولات)
model RestaurantArea {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tables RestaurantTable[]

  @@index([tenantId])
  @@map("restaurant_areas")
}

// طاولة — رقمها نصّي (يدعم "A1"/"طاولة 7")؛ الحالة تُدار في M3 (الكاشير)
model RestaurantTable {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  areaId    String?
  area      RestaurantArea? @relation(fields: [areaId], references: [id], onDelete: SetNull)
  number    String   // رقم/اسم الطاولة
  seats     Int      @default(4)
  status    String   @default("FREE") // FREE | OCCUPIED | BILL_REQUESTED | RESERVED
  posX      Float?   // إحداثيات مخطّط الصالة (لـ M3)
  posY      Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([areaId])
  @@map("restaurant_tables")
}

// قسم في القائمة (مقبّلات، مشاوي، مشروبات...)
model MenuCategory {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MenuItem[]

  @@index([tenantId])
  @@map("menu_categories")
}

// صنف في القائمة — بديل Product لعمودية المطاعم (تسعير أساس + إضافات + محطة تحضير)
model MenuItem {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  code        String   // كود الصنف (فريد لكل مطعم)
  name        String
  description String?
  basePrice   Float
  taxPct      Float    @default(15)
  costPrice   Float    @default(0)   // تكلفة الصنف — لحساب COGS (M6)
  prepStation String   @default("KITCHEN") // KITCHEN | BAR | GRILL | COLD
  itemCode    String?  // كود الصنف للفوترة الإلكترونية (EGS/GS1)
  image       String?  // صورة (base64 data URL)
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modifierGroups MenuItemModifierGroup[]
  orderItems     OrderItem[]
  invoiceItems   InvoiceItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([categoryId])
  @@map("menu_items")
}

// مجموعة إضافات (الحجم، درجة الاستواء، إضافات) — minSelect/maxSelect يحكمان الإلزام والتعدّد
model ModifierGroup {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  minSelect Int      @default(0) // 0 = اختياري
  maxSelect Int      @default(1) // 1 = اختيار واحد؛ >1 = متعدّد
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modifiers Modifier[]
  menuItems MenuItemModifierGroup[]

  @@index([tenantId])
  @@map("modifier_groups")
}

// خيار إضافة واحد داخل مجموعة (كبير +5، جبنة إضافية +3...)
model Modifier {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId    String
  group      ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name       String
  priceDelta Float    @default(0)
  isDefault  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([groupId])
  @@map("modifiers")
}

// ربط صنف بمجموعة إضافات (علاقة كثير-لكثير)
model MenuItemModifierGroup {
  id         String   @id @default(uuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  groupId    String
  group      ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder  Int @default(0)

  @@unique([menuItemId, groupId])
  @@index([groupId])
  @@map("menu_item_modifier_groups")
}

// ============================================================================
// عمودية المطاعم — الكاشير والطلبات والدفع (M3). كلها جداول جديدة (إضافية بحتة).
// ============================================================================

// طلب في الكاشير — يُفتح، تُضاف أصنافه، ثم يُدفع فيولّد فاتورة (checkout.ts)
model Order {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number      Int      // رقم متسلسل معروض لكل مطعم
  channel     String   @default("DINE_IN") // DINE_IN | TAKEAWAY | DELIVERY
  status      String   @default("OPEN")    // OPEN | PAID | VOID
  tableId     String?
  table       RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  cashierName String?  // اسم مشغّل الكاشير (مبسّط في M3)
  guests      Int      @default(1)
  notes       String?

  subtotal         Float @default(0) // صافي قبل الضريبة
  discountAmt      Float @default(0)
  serviceChargeAmt Float @default(0)
  taxAmt           Float @default(0)
  tipAmt           Float @default(0)
  total            Float @default(0)

  invoiceId String?  @unique // القيد الفريد على الجدول الجديد (لا يمسّ جدول الفواتير)
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  voidReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    OrderItem[]
  payments OrderPayment[]

  @@unique([tenantId, number]) // يمنع تكرار رقم الطلب تحت التزامن (مع withNumberRetry)
  @@index([tenantId])
  @@index([status])
  @@index([tableId])
  @@map("orders")
}

// بند في الطلب — لقطة الاسم/السعر لحظة الطلب (سجلّ تاريخي مستقلّ عن تعديل القائمة لاحقاً)
model OrderItem {
  id             String  @id @default(uuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId     String?
  menuItem       MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  nameSnap       String  // لقطة اسم الصنف
  qty            Float   @default(1)
  unitPrice      Float   // سعر الأساس + مجموع الإضافات للوحدة
  modifiersTotal Float   @default(0)
  taxPct         Float   @default(0)
  taxAmt         Float   @default(0)
  lineTotal      Float
  unitCost       Float   @default(0)
  station        String  @default("KITCHEN")
  note           String?
  createdAt      DateTime @default(now())

  modifiers OrderItemModifier[]

  @@index([orderId])
  @@map("order_items")
}

// إضافة مختارة على بند طلب — لقطة الاسم وفرق السعر لحظة الطلب
model OrderItemModifier {
  id          String @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  nameSnap    String
  priceDelta  Float  @default(0)

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

// دفعة على طلب — نقد/بطاقة/محفظة؛ صفوف متعددة = تقسيم الفاتورة (M3b)
model OrderPayment {
  id          String @id @default(uuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method      String @default("CASH") // CASH | CARD | WALLET | ON_ACCOUNT
  amount      Float
  tendered    Float? // المبلغ المستلَم نقداً (لحساب الباقي)
  changeGiven Float?
  reference   String?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@map("order_payments")
}
