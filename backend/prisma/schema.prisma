generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// القيم المسموحة موثّقة بجانب كل حقل

// مالك المنصّة (بائع النظام) — يدير كل الشركات والاشتراكات
model SuperAdmin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

// الشركة المشتركة في النظام — الكيان الأعلى لعزل البيانات
model Tenant {
  id            String    @id @default(uuid())
  name          String    // اسم الشركة المشتركة
  isActive      Boolean   @default(true)  // تعطيل الاشتراك يمنع كل مستخدميها من الدخول
  plan          String    @default("basic") // basic | pro | enterprise (لم يعد يُعرض في الواجهة)
  maxSalesReps  Int?                          // الحد الأقصى لعدد المناديب (null = غير محدود)
  maxAdminUsers Int?                          // الحد الأقصى لمستخدمي لوحة الشركة (null = غير محدود)
  subscriptionEndsAt DateTime?            // تاريخ انتهاء الاشتراك (null = غير محدود)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  admins          Admin[]
  salesReps       SalesRep[]
  categories      ProductCategory[]
  products        Product[]
  customers       Customer[]
  invoices        Invoice[]
  receipts        Receipt[]
  accountEntries  AccountEntry[]
  notifications   Notification[]
  settings        CompanySettings?
  erpIntegration  ErpIntegration?
  erpSyncLogs     ErpSyncLog[]
  vanLoads        VanLoad[]
  repLocations    RepLocation[]
  repSettlements  RepSettlement[]

  @@map("tenants")
}

model Admin {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN | MANAGER | ACCOUNTANT
  isActive     Boolean  @default(true)
  emailVerified Boolean @default(false) // تأكيد ملكية البريد (تحقّق التسجيل الذاتي)

  // Company admin permissions
  canAccessDashboard       Boolean @default(true)
  canManageCustomers       Boolean @default(true)
  canManageProducts        Boolean @default(true)
  canManageSalesReps       Boolean @default(true)
  canManageInvoices        Boolean @default(true)
  canManageReceipts        Boolean @default(true)
  canViewReports           Boolean @default(true)
  canManageVanStock        Boolean @default(true)
  canManageTracking        Boolean @default(true)
  canManageCompanySettings Boolean @default(true)
  canManageCompanyUsers    Boolean @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@map("admins")
}

model SalesRep {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String?
  username     String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  fcmToken     String?

  // Sales permissions
  canCreateInvoice  Boolean @default(true)
  canSellOnCredit   Boolean @default(true)
  canSellInCash     Boolean @default(true)
  canEditInvoice    Boolean @default(false)
  canDeleteInvoice  Boolean @default(false)
  canCancelInvoice  Boolean @default(false)

  // Pricing permissions
  canChangePrice    Boolean @default(false)
  maxDiscountPct    Float   @default(0)
  canSellBelowPrice Boolean @default(false)

  // Collection permissions
  canCreateReceipt  Boolean @default(true)
  canEditReceipt    Boolean @default(false)
  canCancelReceipt  Boolean @default(false)

  // Customer permissions
  canAddCustomer    Boolean @default(false)
  canEditCustomer   Boolean @default(false)
  canViewStatement  Boolean @default(true)

  // إظهار رصيد التحصيل المتراكم للمندوب على شاشته الرئيسية (يحدّده الأدمن لكل مندوب)
  showCollectionBalance Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Van stock permission — هل يستطيع المندوب إدارة مخزون سيارته
  canManageVanStock Boolean @default(true)

  // GPS tracking — آخر موقع معروف + إتاحة التتبّع لهذا المندوب
  canBeTracked Boolean   @default(true)
  lastLat      Float?
  lastLng      Float?
  lastSeenAt   DateTime?

  invoices      Invoice[]
  receipts      Receipt[]
  notifications Notification[]
  vanLoads      VanLoad[]
  locations     RepLocation[]
  settlements   RepSettlement[]

  @@index([tenantId])
  @@map("sales_reps")
}

model ProductCategory {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())
  products  Product[]

  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id           String         @id @default(uuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code         String
  name         String
  barcode      String?
  unit         String
  basePrice    Float
  taxPct       Float          @default(15)
  image        String?        // صورة الصنف (base64 data URL)
  status       String         @default("ACTIVE") // ACTIVE | INACTIVE
  categoryId   String?
  category     ProductCategory? @relation(fields: [categoryId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  priceTiers     PriceTier[]
  customerPrices CustomerPrice[]
  invoiceItems   InvoiceItem[]
  vanLoadItems   VanLoadItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("products")
}

model PriceTier {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  minQty    Float
  maxQty    Float?
  price     Float
  createdAt DateTime @default(now())

  @@map("price_tiers")
}

model Customer {
  id             String         @id @default(uuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String         @default(cuid())
  name           String
  businessName   String?
  commercialReg  String?
  taxNumber      String?
  phone          String
  altPhone       String?
  email          String?
  city           String?
  district       String?
  address        String?
  status         String         @default("ACTIVE") // ACTIVE | INACTIVE | BLOCKED

  creditLimit    Float @default(0)
  paymentDays    Int   @default(30)
  balance        Float @default(0)
  totalSales     Float @default(0)
  totalCollected Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerPrices CustomerPrice[]
  invoices       Invoice[]
  receipts       Receipt[]
  accountEntries AccountEntry[]
  notifications  Notification[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("customers")
}

model CustomerPrice {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, productId])
  @@map("customer_prices")
}

// محتوى الصفحة التعريفية التسويقية والصفحات التابعة (CMS) — صف واحد بمعرّف ثابت "main"
model SiteContent {
  id        String   @id @default("main")
  data      String   // JSON كامل لكل محتوى الصفحة التعريفية والصفحات الفرعية
  updatedAt DateTime @updatedAt @default(now())

  @@map("site_content")
}

model Invoice {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number      String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  salesRepId  String
  salesRep    SalesRep @relation(fields: [salesRepId], references: [id])
  type        String   @default("CREDIT") // CASH | CREDIT | RETURN
  status      String   @default("CONFIRMED") // DRAFT | CONFIRMED | CANCELLED
  invoiceDate DateTime @default(now())
  dueDate     DateTime?
  notes       String?

  subtotal     Float
  discountPct  Float @default(0)
  discountAmt  Float @default(0)
  taxAmt       Float @default(0)
  total        Float
  paidAmt      Float @default(0)
  remainingAmt Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          InvoiceItem[]
  receiptItems   ReceiptInvoice[]
  accountEntries AccountEntry[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  qty         Float
  unitPrice   Float
  discountPct Float   @default(0)
  discountAmt Float   @default(0)
  taxPct      Float
  taxAmt      Float
  lineTotal   Float

  @@map("invoice_items")
}

model Receipt {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number        String
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  salesRepId    String
  salesRep      SalesRep @relation(fields: [salesRepId], references: [id])
  receiptDate   DateTime @default(now())
  amount        Float
  paymentMethod String   @default("CASH") // CASH | BANK_TRANSFER | POS | CHEQUE
  chequeNumber  String?
  bankName      String?
  notes         String?
  status        String   @default("ACTIVE") // ACTIVE | CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoiceItems   ReceiptInvoice[]
  accountEntries AccountEntry[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@map("receipts")
}

model ReceiptInvoice {
  id        String  @id @default(uuid())
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  amount    Float

  @@unique([receiptId, invoiceId])
  @@map("receipt_invoices")
}

model AccountEntry {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  receiptId   String?
  receipt     Receipt? @relation(fields: [receiptId], references: [id])
  type        String   // INVOICE_DEBIT | INVOICE_CREDIT | RECEIPT_CREDIT | RECEIPT_DEBIT | ADJUSTMENT_DEBIT | ADJUSTMENT_CREDIT
  debit       Float    @default(0)
  credit      Float    @default(0)
  balance     Float
  description String
  entryDate   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@map("account_entries")
}

model CompanySettings {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  address       String?
  taxNumber     String?
  commercialReg String?
  phone         String?
  email         String?
  logo          String?  // شعار الشركة (base64 data URL)
  primaryColor  String?  // لون الترويسة الأساسي (hex)
  headerStyle   String?  @default("classic") // classic | banner | minimal
  trackingEnabled Boolean @default(false) // تفعيل تتبّع مواقع المناديب GPS على مستوى الشركة
  updatedAt     DateTime @updatedAt

  @@map("company_settings")
}

model ErpIntegration {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enabled           Boolean  @default(false)
  provider          String   @default("CUSTOM") // CUSTOM | ODOO | SAP | ZOHO | OTHER
  baseUrl           String?
  authType          String   @default("NONE") // NONE | API_KEY | BEARER | BASIC
  apiKey            String?
  bearerToken       String?
  basicUsername     String?
  basicPassword     String?
  customersEndpoint String?
  productsEndpoint  String?
  invoicesEndpoint  String?
  receiptsEndpoint  String?
  syncCustomers     Boolean  @default(true)
  syncProducts      Boolean  @default(true)
  syncInvoices      Boolean  @default(true)
  syncReceipts      Boolean  @default(true)
  lastSyncAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@map("erp_integrations")
}

model ErpSyncLog {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  resource   String    // customers | products | invoices | receipts | connection
  direction  String    @default("OUTBOUND")
  status     String    // SUCCESS | FAILED
  count      Int       @default(0)
  message    String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([tenantId])
  @@index([resource])
  @@map("erp_sync_logs")
}

model Notification {
  id         String    @id @default(uuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type       String    // CREDIT_LIMIT_EXCEEDED | DISCOUNT_LIMIT_EXCEEDED | OVERDUE_PAYMENT | INVOICE_CANCELLED | PRICE_MODIFIED | RECEIPT_CANCELLED
  title      String
  body       String
  salesRepId String?
  salesRep   SalesRep? @relation(fields: [salesRepId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  isRead     Boolean   @default(false)
  data       String?   // JSON كنص
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@map("notifications")
}

// تحميل بضاعة لسيارة المندوب — حركة مخزون (LOAD=تحميل، UNLOAD=تنزيل للمستودع، ADJUST=تسوية)
model VanLoad {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesRepId  String
  salesRep    SalesRep @relation(fields: [salesRepId], references: [id])
  type        String   @default("LOAD") // LOAD | UNLOAD | ADJUST
  note        String?
  createdBy   String?  // "REP" | "ADMIN" — من سجّل الحركة
  createdAt   DateTime @default(now())

  items VanLoadItem[]

  @@index([tenantId])
  @@index([salesRepId])
  @@map("van_loads")
}

model VanLoadItem {
  id        String  @id @default(uuid())
  vanLoadId String
  vanLoad   VanLoad @relation(fields: [vanLoadId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Float   // موجب للتحميل/التسوية الزائدة، يُفسَّر حسب نوع VanLoad

  @@index([vanLoadId])
  @@map("van_load_items")
}

// نقطة موقع GPS للمندوب — سجلّ زمني لرسم خطّ السير ومعرفة الموقع الحالي
model RepLocation {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesRepId String
  salesRep   SalesRep @relation(fields: [salesRepId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  accuracy   Float?   // دقة الموقع بالأمتار
  speed      Float?   // السرعة م/ث إن توفّرت
  capturedAt DateTime // وقت التقاط الموقع على جهاز المندوب
  createdAt  DateTime @default(now())

  @@index([tenantId, salesRepId, capturedAt])
  @@map("rep_locations")
}

// استلام تحصيل من المندوب — كل مرّة يسلّم فيها المندوب نقدًا للإدارة يُسجَّل هنا.
// رصيد التحصيل لدى المندوب = مجموع سنداته النشطة − مجموع ما سُجّل هنا من استلامات.
model RepSettlement {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesRepId String
  salesRep   SalesRep @relation(fields: [salesRepId], references: [id], onDelete: Cascade)
  amount     Float
  note       String?
  createdBy  String?  // اسم/معرّف الأدمن الذي استلم
  settledAt  DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([tenantId, salesRepId])
  @@map("rep_settlements")
}

// ============================================================================
// العملاء المحتملون (Leads) — على مستوى المنصّة (مالك المنصّة / السوبر أدمن)
// شركات توزيع/جملة حول العالم قد تشترك في Field Sales. مستقلة عن أي Tenant.
// ============================================================================

// عميل محتمل واحد (شركة) — تُجمع من الخرائط/المصادر العامة أو يدوياً
model Lead {
  id          String  @id @default(uuid())
  name        String  // اسم النشاط/الشركة
  phone       String?
  email       String?
  website     String?
  address     String?
  city        String?
  country     String? // اسم الدولة (للعرض)
  countryCode String? // ISO-3166 alpha-2 (للتجميع والفلترة)
  category    String? // نوع النشاط (تجارة جملة، موزّع...)
  lat         Float?
  lng         Float?
  mapsUrl     String? // رابط الموقع على الخريطة

  source   String  @default("manual") // manual | csv | osm | google | social | api
  sourceId String? @unique            // مفتاح إزالة التكرار لكل مصدر (مثل "osm:node/123")

  // خط أنابيب المبيعات
  stage   String  @default("NEW") // NEW | CONTACTED | QUALIFIED | PROPOSAL | WON | LOST
  score   Int?    // ملاءمة 1-10 (تأهيل آلي/يدوي)
  scoreNote String?
  assignedTo String? // معرّف/اسم مسؤول المتابعة (سوبر أدمن)
  convertedTenantId String? // عند التحويل لمشترك فعلي
  notes   String?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities LeadActivity[]

  @@index([stage])
  @@index([countryCode])
  @@index([source])
  @@index([nextFollowUpAt])
  @@map("leads")
}

// سجلّ نشاط/متابعة على عميل محتمل (مكالمة، ملاحظة، تغيير مرحلة...)
model LeadActivity {
  id      String @id @default(uuid())
  leadId  String
  lead    Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type    String // NOTE | CALL | EMAIL | MEETING | STAGE_CHANGE | SCORE | IMPORT
  content String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("lead_activities")
}

// سجلّ عملية بحث آلي (لتتبّع مصادر الجمع وتجنّب التكرار وعرض التاريخ)
model LeadSearch {
  id       String @id @default(uuid())
  provider String // osm | google
  query    String // نوع النشاط المبحوث عنه
  country  String?
  city     String?
  status   String @default("done") // running | done | failed
  found    Int    @default(0) // إجمالي النتائج من المصدر
  imported Int    @default(0) // الجدد المُضافون بعد إزالة التكرار
  error    String?
  createdBy String?
  createdAt DateTime @default(now())

  @@map("lead_searches")
}

// ============================================================================
// تحليلات زيارات الموقع التعريفي — على مستوى المنصّة (مالك المنصّة / السوبر أدمن)
// تُسجَّل زيارة لكل تحميل صفحة عامّة، مع تحديد الدولة/المدينة من IP (بدون تخزين IP خام).
// ============================================================================
model Visit {
  id           String   @id @default(uuid())
  path         String   // مسار الصفحة (/ , /blog , /en ...)
  lang         String?  // ar | en
  referrer     String?  // الرابط المُحيل الكامل
  referrerHost String?  // نطاق المُحيل (google.com ...) أو null للزيارة المباشرة
  country      String?
  countryCode  String?  // ISO alpha-2
  region       String?
  city         String?
  ipHash       String?  // بصمة IP مجزّأة (لعدّ الزوّار الفريدين دون تخزين IP الخام)
  userAgent    String?
  isBot        Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([countryCode])
  @@index([referrerHost])
  @@map("visits")
}
